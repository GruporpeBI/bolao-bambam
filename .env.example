# ─────────────────────────────────────────────────────────────────────────────
# Bolão Copa 2026 — Mercearia Amauri
# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# NUNCA commite .env.local no git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Crie um projeto em https://supabase.com
# Copie de: Settings → API → Project URL / anon public key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API de futebol ────────────────────────────────────────────────────────────
# Conta gratuita em https://www.football-data.org (10 req/min)
# Usado para sincronizar jogos da Copa do Mundo 2026
FOOTBALL_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin ────────────────────────────────────────────────────────────────────
# E-mail do administrador do bolão (deve coincidir com o usuário no Supabase Auth)
# Dá acesso à rota /admin
ADMIN_EMAIL=admin@merceariaamauri.com.br

# ── Multi-source polling ──────────────────────────────────────────────────────
# Secret para autenticar chamada ao /api/sync-result (Edge Functions → Next.js)
SYNC_SECRET=bolao_sync_2026

# API-Football — chave primária e fallback (key2 é usada quando key1 atinge rate limit)
# Cadastro gratuito em https://dashboard.api-sports.io (100 req/dia por chave)
API_FOOTBALL_KEY=
API_FOOTBALL_KEY_2=

# URL do app Next.js em produção (Vercel) — usada pelas Edge Functions
APP_URL=https://seu-projeto.vercel.app
